# Sensorlinx account credentials (required for live tests and examples)
SENSORLINX_EMAIL=your-email@example.com
SENSORLINX_PASSWORD=your-password

# Optional: pin a specific building / device. If omitted, the
# examples/system_state.py script auto-discovers the first of each.
# SENSORLINX_BUILDING_ID=
# SENSORLINX_DEVICE_ID=
